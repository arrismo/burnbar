MAC_RELEASE_APP_NAME=Burnbar
MAC_RELEASE_REPO=arrismo/burnbar
MAC_RELEASE_BUNDLE_ID=com.arrismo.burnbar
MAC_RELEASE_VERSION_FILE=version.env
MAC_RELEASE_APPCAST=appcast.xml
MAC_RELEASE_SOURCE_FILES='Scripts/release_artifacts.sh'
MAC_RELEASE_SUPUBLIC_ED_KEY=REPLACE_WITH_BURNBAR_SPARKLE_PUBLIC_KEY
# Set this to Burnbar's private Sparkle key before releasing. Do not reuse CodexBar's key.
MAC_RELEASE_SIGNING_KEY_FILE=''

MAC_RELEASE_APP_ZIP='$(codexbar_app_zip_name "$MARKETING_VERSION" "${ARCHES:-arm64 x86_64}")'
MAC_RELEASE_DSYM_ZIP='$(codexbar_dsym_zip_name "$MARKETING_VERSION" "${ARCHES:-arm64 x86_64}")'
MAC_RELEASE_ARTIFACT_PREFIX='Burnbar-macos-[A-Za-z0-9_+-]+-'
MAC_RELEASE_FEED_URL='https://raw.githubusercontent.com/arrismo/burnbar/main/appcast.xml'
MAC_RELEASE_DOWNLOAD_URL_PREFIX='https://github.com/arrismo/burnbar/releases/download/v${MARKETING_VERSION}/'

MAC_RELEASE_PRECHECK='swiftformat Sources Tests >/dev/null && swiftlint --strict && swift test'
MAC_RELEASE_PACKAGE_CMD='Scripts/sign-and-notarize.sh'
MAC_RELEASE_TAG_SIGNED=1
MAC_RELEASE_TAG_FORCE=1
MAC_RELEASE_GENERATE_APPCAST_ARGS='--maximum-deltas 0'
MAC_RELEASE_EXTRA_ASSET_WAIT_SECONDS=3600
MAC_RELEASE_EXTRA_ASSET_WAIT_INTERVAL=30
MAC_RELEASE_EXTRA_ASSET_PATTERNS='^BurnbarCLI-v${MARKETING_VERSION}-macos-arm64\.tar\.gz$
^BurnbarCLI-v${MARKETING_VERSION}-macos-arm64\.tar\.gz\.sha256$
^BurnbarCLI-v${MARKETING_VERSION}-macos-x86_64\.tar\.gz$
^BurnbarCLI-v${MARKETING_VERSION}-macos-x86_64\.tar\.gz\.sha256$
^BurnbarCLI-v${MARKETING_VERSION}-linux-aarch64\.tar\.gz$
^BurnbarCLI-v${MARKETING_VERSION}-linux-aarch64\.tar\.gz\.sha256$
^BurnbarCLI-v${MARKETING_VERSION}-linux-x86_64\.tar\.gz$
^BurnbarCLI-v${MARKETING_VERSION}-linux-x86_64\.tar\.gz\.sha256$'
